}

// ─── OPS DASHBOARD ───────────────────────────────────────────────
function OpsDashboard() {
  const [trips, setTrips] = useState([]);
  const [claims, setClaims] = useState([]);
  const [pos, setPos] = useState([]);

  useEffect(() => {
    store.get("travelRequests").then(d => d && setTrips(d));
    store.get("expenseClaims").then(d => d && setClaims(d));
    store.get("poRequests").then(d => d && setPos(d));
  }, []);

  const totalExpenses = claims.reduce((s,c) => s + (c.totalGBP||0), 0);
  const totalPO = pos.reduce((s,p) => s + (p.amount||0), 0);
  const pendingTrips = trips.filter(t => t.status === "pending_approval").length;
  const approvedTrips = trips.filter(t => t.status === "approved").length;

  // Expenses by institution
  const expByInst = {};
  claims.forEach(c => { (c.institutions||[]).forEach(inst => { expByInst[inst] = (expByInst[inst]||0) + (c.totalGBP||0)/c.institutions.length; }); });

  return (
    <div>
      <div style={{ display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:14,marginBottom:24 }}>
        {[
          {l:"Travel Requests",v:trips.length,sub:`${pendingTrips} pending · ${approvedTrips} approved`,c:"var(--navy)"},
          {l:"Expense Claims",v:claims.length,sub:`£${totalExpenses.toFixed(0)} total`,c:"var(--gold)"},
          {l:"PO Requests",v:pos.length,sub:`£${totalPO.toFixed(0)} total value`,c:"var(--navy)"},
          {l:"Total Receipts",v:claims.reduce((s,c)=>s+c.receipts.length,0),sub:"across all claims",c:"#2d6a4f"},
        ].map(m => (
          <Card key={m.l}>
            <div style={{ fontSize:10,fontWeight:600,color:"#8c9aab",letterSpacing:1,textTransform:"uppercase",marginBottom:6 }}>{m.l}</div>
            <div style={{ fontSize:30,fontWeight:400,fontFamily:"var(--serif)",color:m.c }}>{m.v}</div>
            <div style={{ fontSize:11,color:"#8c9aab",marginTop:4 }}>{m.sub}</div>
          </Card>
        ))}
      </div>

      {/* Expenses by institution */}
      <Card style={{ marginBottom:16 }}>
        <div style={{ fontSize:13,fontFamily:"var(--serif)",color:"var(--navy)",marginBottom:16 }}>Expenses by Institution</div>
        {Object.keys(expByInst).length === 0 ? <div style={{ color:"#8c9aab",fontSize:12 }}>No expenses logged yet</div> :
          Object.entries(expByInst).sort((a,b)=>b[1]-a[1]).map(([inst,amt]) => (
            <div key={inst} style={{ display:"flex",justifyContent:"space-between",alignItems:"center",padding:"8px 0",borderBottom:"1px solid #f0eeeb" }}>
              <div style={{ display:"flex",alignItems:"center",gap:8 }}>
                <Badge gold>{inst}</Badge>
              </div>
              <span style={{ fontWeight:700,fontFamily:"var(--serif)" }}>£{amt.toFixed(2)}</span>
            </div>
          ))
        }
      </Card>

      {/* Recent POs */}
      <Card>
        <div style={{ fontSize:13,fontFamily:"var(--serif)",color:"var(--navy)",marginBottom:16 }}>Recent PO Requests</div>
        {pos.length === 0 ? <div style={{ color:"#8c9aab",fontSize:12 }}>No PO requests</div> :
          pos.slice(0,5).map(p => (
            <div key={p.id} style={{ display:"flex",justifyContent:"space-between",alignItems:"center",padding:"8px 0",borderBottom:"1px solid #f0eeeb",fontSize:12 }}>
              <div>
                <div style={{ fontWeight:600 }}>{p.supplierName}</div>
                <div style={{ color:"#8c9aab",fontSize:11 }}>{p.ref} · {p.institutions.join(", ")}</div>
              </div>
              <div style={{ fontWeight:700,fontFamily:"var(--serif)" }}>{p.amount} {p.currency}</div>
            </div>
          ))
        }
      </Card>
    </div>
  );
}


