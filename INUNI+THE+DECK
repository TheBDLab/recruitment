          <tbody>{sorted.slice(0,20).map((a,i) => { const score = period==="year"?a.apps+a.deps+a.enr:a.monthApps+a.monthDeps; return (
            <tr key={a.id} style={{ borderBottom:"1px solid #f0eeeb" }}>
