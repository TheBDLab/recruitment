// ─── ECO - FLOATING PENGUIN ASSISTANT ────────────────────────────
function PenguinAssistant({ onNavigate }) {
  const [open, setOpen] = useState(false);
  const [hasOpened, setHasOpened] = useState(false);
  const [query, setQuery] = useState("");
  const [typedText, setTypedText] = useState("");
  const [mode, setMode] = useState("home");
  const [step, setStep] = useState(0);
  const [draft, setDraft] = useState({});
  const [ecoMsg, setEcoMsg] = useState("");
  const [saved, setSaved] = useState(false);
  const [customInput, setCustomInput] = useState("");

  const introMsg = "Hello superstar! Eco is here, how do we make this day count?";

  useEffect(() => {
    if (open && !hasOpened) {
      setHasOpened(true);
      setTypedText("");
      let i = 0;
      const interval = setInterval(() => {
        i++;
        setTypedText(introMsg.slice(0, i));
        if (i >= introMsg.length) clearInterval(interval);
      }, 28);
      return () => clearInterval(interval);
    }
  }, [open, hasOpened]);

  const resetFlow = () => { setMode("home"); setStep(0); setDraft({}); setEcoMsg(""); setSaved(false); setCustomInput(""); };

  const activitySteps = [
    { key:"type", eco:"What did you do, superstar?", options: ACTIVITY_TYPES },
    { key:"agent", eco:"Which agent was this with?", options: SAMPLE_AGENTS.slice(0,12), allowCustom: true },
    { key:"university", eco:"Which university does this relate to?", options: UNIVERSITIES, allowSkip: true },
    { key:"notes", eco:"Quick summary — just tap one or skip!", options: [
      "Positive discussion, follow-up needed",
      "Needs more info, will reconnect",
      "Strong pipeline, ready to convert",
      "Training completed successfully",
      "New opportunity identified",
      "Issue raised, escalation needed",
      "Routine check-in, all on track",
    ], allowSkip: true, allowCustom: true },
  ];

  const taskSteps = [
    { key:"title", eco:"What kind of task do you need?", options: [
      "Follow up with agent",
      "Send commission structure",
      "Prepare training materials",
      "Submit application review",
      "Chase deposit payment",
      "Schedule onboarding call",
      "Update agent portfolio",
      "Review enrolment status",
      "Prepare intake report",
      "Respond to admission query",
    ], allowCustom: true },
    { key:"priority", eco:"How urgent is this?", options: [
      { label: "\u{1F534} Urgent — needs attention now", value: "urgent" },
      { label: "\u{1F7E1} High — today if possible", value: "high" },
      { label: "\u{1F535} Medium — this week", value: "medium" },
      { label: "\u26AA Low — when you get a chance", value: "low" },
    ]},
    { key:"source", eco:"Where did this come from?", options: [
      { label: "My own initiative", value: "self" },
      { label: "Engine Room assigned it", value: "Engine Room" },
      { label: "Follow-up from an activity", value: "Activity Follow-up" },
    ]},
    { key:"dueDate", eco:"When does this need to be done?", options: [
      { label: "Today", value: new Date().toISOString().slice(0,10) },
      { label: "Tomorrow", value: new Date(Date.now()+86400000).toISOString().slice(0,10) },
      { label: "This week", value: new Date(Date.now()+5*86400000).toISOString().slice(0,10) },
      { label: "Next week", value: new Date(Date.now()+7*86400000).toISOString().slice(0,10) },
      { label: "No deadline", value: "" },
    ]},
  ];

  const currentSteps = mode === "logActivity" ? activitySteps : mode === "logTask" ? taskSteps : [];
  const currentStep = currentSteps[step];

  const handleSelect = async (value) => {
    const newDraft = { ...draft, [currentStep.key]: value };
    setDraft(newDraft);

    if (step < currentSteps.length - 1) {
      setStep(step + 1);
      setCustomInput("");
    } else {
      setMode("confirm");
      setCustomInput("");
      if (mode === "logActivity") {
        const activities = (await store.get("activities")) || [];
        const entry = { id: Date.now(), type: newDraft.type || "", agent: newDraft.agent || "", university: newDraft.university || "", notes: newDraft.notes || "", timestamp: new Date().toISOString() };
        await store.set("activities", [entry, ...activities]);
        setEcoMsg("Boom! I\u2019ve logged your \u201C" + (newDraft.type||"activity") + "\u201D with " + (newDraft.agent||"the agent") + ". Keep crushing it, superstar!");
      } else {
        const tasks = (await store.get("tasks")) || [];
        const entry = { id: Date.now(), title: newDraft.title || "", priority: newDraft.priority || "medium", source: newDraft.source || "self", dueDate: newDraft.dueDate || "", notes: "", status: "pending", created: new Date().toISOString() };
        await store.set("tasks", [entry, ...tasks]);
        setEcoMsg("Task locked in! \u201C" + (newDraft.title||"task") + "\u201D is on your list. You\u2019ve got this!");
      }
      setSaved(true);
    }
  };

  const handleSkip = () => {
    const newDraft = { ...draft, [currentStep.key]: "" };
    setDraft(newDraft);
    if (step < currentSteps.length - 1) { setStep(step + 1); setCustomInput(""); }
    else handleSelect("");
  };

  const quickActions = [
    { label: "Quick Log Activity", desc: "Tap through \u2014 no typing needed", action: "logActivity", icon: "activity", highlight: true },
    { label: "Quick Add Task", desc: "Eco builds it, you just tap", action: "logTask", icon: "tasks", highlight: true },
    { label: "View sales dashboard", desc: "Targets, actuals & bonuses", section: "dashboard", icon: "chart" },
    { label: "Raise admission request", desc: "Urgent issue? Flag it now", section: "tickets", icon: "ticket" },
    { label: "See announcements", desc: "Latest from Engine Room", section: "announcements", icon: "megaphone" },
    { label: "Agent performance", desc: "Top agents & portfolio", section: "agents", icon: "agents" },
    { label: "Knowledge room", desc: "University docs & resources", section: "knowledge", icon: "book" },
  ];

  const filtered = query
    ? quickActions.filter(a => a.label.toLowerCase().includes(query.toLowerCase()) || a.desc.toLowerCase().includes(query.toLowerCase()))
    : quickActions;

  const EcoBubble = ({ msg }) => (
    <div style={{ display:"flex",gap:10,alignItems:"flex-start",marginBottom:10 }}>
      <div style={{ flexShrink:0,width:26,height:26,borderRadius:"50%",background:"rgba(255,255,255,.12)",border:"1.5px solid rgba(212,168,71,.3)",display:"flex",alignItems:"center",justifyContent:"center" }}>
        <PenguinMascot size={18} />
      </div>
      <div style={{ background:"rgba(255,255,255,.08)",borderRadius:"2px 10px 10px 10px",padding:"10px 14px",flex:1,borderLeft:"2px solid var(--gold)" }}>
        <div style={{ color:"#ffffff",fontSize:13,lineHeight:1.6,fontWeight:500 }}>{msg}</div>
      </div>
    </div>
  );

  const ProgressDots = () => (
    <div style={{ display:"flex",gap:5,marginBottom:12 }}>
      {currentSteps.map((_, i) => (
        <div key={i} style={{ width: i === step ? 20 : 8, height: 6, borderRadius: 3, background: i < step ? "var(--gold)" : i === step ? "#ffffff" : "rgba(255,255,255,.2)", transition: "all .3s" }} />
      ))}
    </div>
  );

  return (
    <>
      {/* Floating Eco button */}
      <div style={{ position:"fixed",bottom:24,right:24,zIndex:1000,display:"flex",flexDirection:"column",alignItems:"center",gap:4 }}>
        {!open && (
          <div style={{ background:"var(--navy)",color:"#fff",padding:"5px 12px",borderRadius:20,fontSize:10,fontWeight:700,letterSpacing:1.5,textTransform:"uppercase",boxShadow:"0 2px 8px rgba(0,0,0,.15)",animation:"ecoPulse 2s ease-in-out infinite" }}>
            Ask Eco
          </div>
        )}
        <button onClick={() => { if(open) { setOpen(false); resetFlow(); } else setOpen(true); }} style={{
          width:68,height:68,borderRadius:"50%",border:"3px solid var(--gold)",
          background:"linear-gradient(135deg,#ffffff,#faf6ed)",cursor:"pointer",
          boxShadow: open ? "0 4px 20px rgba(0,0,0,.15)" : "0 4px 24px rgba(184,134,11,.25), 0 0 0 6px rgba(184,134,11,.08)",
          display:"flex",alignItems:"center",justifyContent:"center",transition:"all .3s",
          transform: open ? "scale(0.92)" : "scale(1)"
        }}>
          {open
            ? <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a2a3a" strokeWidth="2.5" strokeLinecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            : <PenguinMascot size={48} />
          }
        </button>
      </div>

      {/* Eco panel */}
      {open && (
        <div style={{
          position:"fixed",bottom:108,right:24,width:380,borderRadius:16,background:"#ffffff",
          border:"1px solid #e8e6e1",boxShadow:"0 16px 48px rgba(0,0,0,.14)",zIndex:1000,
          overflow:"hidden",display:"flex",flexDirection:"column",maxHeight:"80vh",
          animation:"ecoSlideUp .3s ease"
        }}>
          <style>{`
            @keyframes ecoSlideUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
            @keyframes ecoPulse { 0%,100% { transform:scale(1); } 50% { transform:scale(1.05); } }
            @keyframes ecoBlink { 0%,50% { opacity:1; } 51%,100% { opacity:0; } }
            @keyframes ecoFadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }
          `}</style>

          {/* ═══ HOME ═══ */}
          {mode === "home" && (<>
            <div style={{ padding:"22px 22px 18px",background:"linear-gradient(135deg,#1a2a3a 0%,#2a3f54 100%)",position:"relative",overflow:"hidden",flexShrink:0 }}>
              <div style={{ position:"absolute",top:-20,right:-20,width:80,height:80,borderRadius:"50%",border:"1px solid rgba(212,168,71,.15)" }} />
              <div style={{ display:"flex",alignItems:"center",gap:16,position:"relative" }}>
