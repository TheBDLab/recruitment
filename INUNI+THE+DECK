// ─── SECTION 1: ACTIVITY LOG ─────────────────────────────────────
function ActivityLog() {
  const [activities, setActivities] = useState([]);
  const [form, setForm] = useState({ type:"", agent:"", notes:"", university:"" });
  const [showForm, setShowForm] = useState(false);

  useEffect(() => { store.get("activities").then(d => d && setActivities(d)); }, []);
  const save = (a) => { setActivities(a); store.set("activities", a); };

  const submit = () => {
    if (!form.type || !form.agent) return;
    save([{ ...form, id: Date.now(), timestamp: new Date().toISOString() }, ...activities]);
    setForm({ type:"", agent:"", notes:"", university:"" });
    setShowForm(false);
  };

  const del = (id) => save(activities.filter(a => a.id !== id));
  const today = activities.filter(a => new Date(a.timestamp).toDateString() === new Date().toDateString());

  return (
    <div>
      <SectionHeader eyebrow="Daily Tracker" title="Activity Log" right={<Btn gold icon="plus" onClick={() => setShowForm(!showForm)}>{showForm ? "Cancel" : "Log Activity"}</Btn>} />
      <div style={{ display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:16,marginBottom:28 }}>
        <Card><div style={{ fontSize:11,fontWeight:600,color:"#8c9aab",letterSpacing:1.2,textTransform:"uppercase",marginBottom:8 }}>Today</div><div style={{ fontSize:36,fontWeight:400,fontFamily:"var(--serif)",color:"var(--navy)" }}>{today.length}</div></Card>
        <Card><div style={{ fontSize:11,fontWeight:600,color:"#8c9aab",letterSpacing:1.2,textTransform:"uppercase",marginBottom:8 }}>This Week</div><div style={{ fontSize:36,fontWeight:400,fontFamily:"var(--serif)",color:"var(--navy)" }}>{activities.filter(a => { const d = new Date(a.timestamp); const now = new Date(); return d > new Date(now.setDate(now.getDate()-7)); }).length}</div></Card>
        <Card><div style={{ fontSize:11,fontWeight:600,color:"#8c9aab",letterSpacing:1.2,textTransform:"uppercase",marginBottom:8 }}>Total</div><div style={{ fontSize:36,fontWeight:400,fontFamily:"var(--serif)",color:"var(--navy)" }}>{activities.length}</div></Card>
      </div>
      {showForm && (
        <Card style={{ marginBottom:24,borderLeft:"3px solid var(--gold)" }}>
          <div style={{ fontSize:13,fontWeight:600,marginBottom:20,color:"var(--gold)",letterSpacing:1.5,textTransform:"uppercase" }}>New Activity Entry</div>
          <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:20 }}>
            <Select label="Activity Type" options={ACTIVITY_TYPES} value={form.type} onChange={e => setForm({...form, type:e.target.value})} />
            <Input label="Agent Name" placeholder="e.g. Apex Education" value={form.agent} onChange={e => setForm({...form, agent:e.target.value})} />
            <Select label="University" options={UNIVERSITIES} value={form.university} onChange={e => setForm({...form, university:e.target.value})} />
            <TextArea label="Discussion Summary" placeholder="Key discussion points..." value={form.notes} onChange={e => setForm({...form, notes:e.target.value})} />
          </div>
          <div style={{ marginTop:20,display:"flex",justifyContent:"flex-end" }}><Btn gold icon="send" onClick={submit}>Submit to Engine Room</Btn></div>
        </Card>
      )}
      <div style={{ display:"flex",flexDirection:"column",gap:1 }}>
        {activities.length === 0 && <EmptyState icon="activity" title="No Activities Logged" sub="Start logging your daily activities to keep Engine Room informed" />}
        {activities.slice(0, 30).map(a => (
          <div key={a.id} style={{ display:"flex",alignItems:"center",gap:18,padding:"16px 0",borderBottom:"1px solid #f0eeeb" }}>
            <div style={{ width:44,height:44,borderRadius:4,background:"#f7f6f3",display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0,color:"var(--navy)" }}><Icon name="activity" size={18} /></div>
            <div style={{ flex:1,minWidth:0 }}>
              <div style={{ display:"flex",alignItems:"center",gap:8,flexWrap:"wrap" }}>
                <span style={{ fontWeight:600,fontSize:14,fontFamily:"var(--serif)",color:"var(--navy)" }}>{a.type}</span>
                <Badge color="var(--navy)">{a.agent}</Badge>
                {a.university && <Badge gold>{a.university}</Badge>}
              </div>
              {a.notes && <div style={{ fontSize:13,color:"#8c9aab",marginTop:4,whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis" }}>{a.notes}</div>}
            </div>
            <div style={{ textAlign:"right",flexShrink:0 }}>
              <div style={{ fontSize:11,color:"#8c9aab" }}>{new Date(a.timestamp).toLocaleTimeString("en-GB",{hour:"2-digit",minute:"2-digit"})}</div>
              <div style={{ fontSize:10,color:"#b8b5ae" }}>{new Date(a.timestamp).toLocaleDateString("en-GB",{day:"numeric",month:"short"})}</div>
            </div>
            <button onClick={() => del(a.id)} style={{ background:"none",border:"none",cursor:"pointer",color:"#c8c5be",padding:4 }}><Icon name="trash" size={14} /></button>
          </div>
        ))}
      </div>
    </div>
  );
}

// ─── SECTION 2: TASKS ────────────────────────────────────────────
function Tasks() {
  const [tasks, setTasks] = useState([]);
  const [form, setForm] = useState({ title:"", priority:"medium", dueDate:"", source:"self", notes:"" });
  const [showForm, setShowForm] = useState(false);
  const [filter, setFilter] = useState("all");

  useEffect(() => { store.get("tasks").then(d => d && setTasks(d)); }, []);
  const save = (t) => { setTasks(t); store.set("tasks", t); };

  const submit = () => {
    if (!form.title) return;
    save([{ ...form, id: Date.now(), status:"pending", created: new Date().toISOString() }, ...tasks]);
    setForm({ title:"", priority:"medium", dueDate:"", source:"self", notes:"" });
    setShowForm(false);
  };
  const toggle = (id) => save(tasks.map(t => t.id === id ? { ...t, status: t.status === "done" ? "pending" : "done" } : t));
  const del = (id) => save(tasks.filter(t => t.id !== id));
  const filtered = filter === "all" ? tasks : filter === "active" ? tasks.filter(t => t.status !== "done") : tasks.filter(t => t.status === "done");
  const pending = tasks.filter(t => t.status !== "done").length;

  return (
    <div>
      <SectionHeader eyebrow="Task Manager" title="Your Tasks" right={<Btn gold icon="plus" onClick={() => setShowForm(!showForm)}>{showForm ? "Cancel" : "New Task"}</Btn>} />
      <div style={{ display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:14,marginBottom:24 }}>
        {[{l:"Pending",v:pending,c:"var(--gold)"},{l:"Urgent",v:tasks.filter(t=>t.priority==="urgent"&&t.status!=="done").length,c:"#c0392b"},{l:"Engine Room",v:tasks.filter(t=>t.source==="Engine Room").length,c:"var(--navy)"},{l:"Completed",v:tasks.filter(t=>t.status==="done").length,c:"#2d6a4f"}].map(m => (
          <Card key={m.l}><div style={{ fontSize:10,fontWeight:600,color:"#8c9aab",letterSpacing:1.2,textTransform:"uppercase",marginBottom:6 }}>{m.l}</div><div style={{ fontSize:30,fontWeight:400,fontFamily:"var(--serif)",color:m.c }}>{m.v}</div></Card>
        ))}
      </div>
      {showForm && (
        <Card style={{ marginBottom:24,borderLeft:"3px solid var(--gold)" }}>
          <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:20 }}>
            <div style={{ gridColumn:"1/3" }}><Input label="Task Title" placeholder="What needs to be done?" value={form.title} onChange={e => setForm({...form, title:e.target.value})} /></div>
            <Select label="Priority" options={["urgent","high","medium","low"]} value={form.priority} onChange={e => setForm({...form, priority:e.target.value})} />
            <Input label="Due Date" type="date" value={form.dueDate} onChange={e => setForm({...form, dueDate:e.target.value})} />
            <Select label="Source" options={["self","Engine Room","Activity Follow-up"]} value={form.source} onChange={e => setForm({...form, source:e.target.value})} />
            <TextArea label="Notes" value={form.notes} onChange={e => setForm({...form, notes:e.target.value})} />
          </div>
          <div style={{ marginTop:18,display:"flex",justifyContent:"flex-end" }}><Btn gold icon="plus" onClick={submit}>Add Task</Btn></div>
        </Card>
      )}
      <div style={{ marginBottom:20 }}><TabBar tabs={[{id:"all",label:"All"},{id:"active",label:"Active"},{id:"done",label:"Completed"}]} active={filter} onChange={setFilter} /></div>
      <div style={{ display:"flex",flexDirection:"column",gap:1 }}>
        {filtered.length === 0 && <EmptyState icon="tasks" title="No Tasks" sub="Add tasks or they'll auto-generate from activities" />}
        {filtered.map(t => (
          <div key={t.id} style={{ display:"flex",alignItems:"center",gap:14,padding:"14px 0",borderBottom:"1px solid #f0eeeb",opacity:t.status==="done"?0.45:1 }}>
            <button onClick={() => toggle(t.id)} style={{ width:22,height:22,borderRadius:3,border:`2px solid ${PRIORITY_COLORS[t.priority]}`,background:t.status==="done"?PRIORITY_COLORS[t.priority]:"transparent",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0,color:"#fff" }}>
              {t.status === "done" && <Icon name="check" size={11} />}
            </button>
            <div style={{ flex:1 }}>
              <div style={{ fontWeight:500,fontSize:14,textDecoration:t.status==="done"?"line-through":"none",color:"var(--navy)",fontFamily:"var(--serif)" }}>{t.title}</div>
              <div style={{ display:"flex",gap:6,marginTop:5,flexWrap:"wrap" }}>
                <Badge color={PRIORITY_COLORS[t.priority]}>{t.priority}</Badge>
                {t.source !== "self" && <Badge gold>{t.source}</Badge>}
                {t.dueDate && <Badge color="#8c9aab">{t.dueDate}</Badge>}
              </div>
            </div>
            <button onClick={() => del(t.id)} style={{ background:"none",border:"none",cursor:"pointer",color:"#c8c5be",padding:4 }}><Icon name="trash" size={14} /></button>
          </div>
        ))}
      </div>
    </div>
  );
}

