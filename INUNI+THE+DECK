              </div>
            )}
            <div style={{ display:"flex",gap:8,marginTop:14 }}>
              {t.status === "pending_approval" && <Btn gold onClick={() => approveTrip(t.id)}>Approve (Team Leader)</Btn>}
              {t.status === "approved" && <Btn variant="secondary">Extract to Excel</Btn>}
            </div>
          </Card>
        );
      })()}

      {/* Trip list */}
      {trips.length === 0 && <EmptyState icon="send" title="No Travel Requests" sub="Submit your first travel request" />}
      {trips.map(t => (
        <div key={t.id} onClick={() => setSelected(t.id)} style={{ display:"flex",alignItems:"center",gap:14,padding:"14px 0",borderBottom:"1px solid #f0eeeb",cursor:"pointer" }}>
          <div style={{ width:42,height:42,borderRadius:4,background:"#f7f6f3",display:"flex",alignItems:"center",justifyContent:"center",color:"var(--gold)" }}><Icon name="send" size={18} /></div>
          <div style={{ flex:1 }}>
            <div style={{ fontWeight:600,fontSize:14,fontFamily:"var(--serif)" }}>{t.tripName}</div>
            <div style={{ fontSize:11,color:"#8c9aab",marginTop:2 }}>{t.ref} · {t.startDate} — {t.endDate} · {t.costCentres.join(", ")}</div>
          </div>
          <Badge color={t.status==="approved"?"#2d6a4f":"var(--gold)"}>{t.status.replace("_"," ")}</Badge>
        </div>
      ))}
    </div>
  );
}

// ─── EXPENSES ────────────────────────────────────────────────────
function ExpensesSection({ user }) {
  const [claims, setClaims] = useState([]);
  const [trips, setTrips] = useState([]);
  const [showForm, setShowForm] = useState(false);
  const [form, setForm] = useState({ name:"", linkedTrip:"", startDate:"", endDate:"", institutions:[""], receipts:[] });
  const [scanResult, setScanResult] = useState(null);
  const [scanError, setScanError] = useState("");

  useEffect(() => {
    store.get("expenseClaims").then(d => d && setClaims(d));
    store.get("travelRequests").then(d => d && setTrips(d));
  }, []);
  const save = (c) => { setClaims(c); store.set("expenseClaims", c); };

  const addInstitution = () => { if(form.institutions.length < 3) setForm({...form, institutions:[...form.institutions, ""]}); };
  const updateInstitution = (i,val) => { const inst=[...form.institutions]; inst[i]=val; setForm({...form,institutions:inst}); };

  // Validate institutions against targets
  const salesData = useRef(null);
  useEffect(() => { store.get("salesData").then(d => { salesData.current = d; }); }, []);

  const hasTarget = (uni) => {
    if(!salesData.current) return true;
    let total = 0;
    Object.values(salesData.current.intakes).forEach(intake => {
      if(intake[uni]) total += intake[uni].applicationTarget + intake[uni].depositTarget;
    });
    return total > 0;
  };

  // GBP conversion rates (simplified)
  const toGBP = (amount, currency) => {
    const rates = { GBP:1, USD:0.79, EUR:0.86, AED:0.22, NGN:0.00051, INR:0.0095, PKR:0.0028, EGP:0.016, SAR:0.21, CNY:0.11 };
    return Math.round((amount * (rates[currency] || 0.79)) * 100) / 100;
  };

  // AI Receipt Scanner (simulated)
  const scanReceipt = () => {
    setScanError("");
    // Simulate AI reading a receipt
    const currencies = ["GBP","USD","EUR","AED","NGN","INR"];
    const descriptions = ["Business lunch with agent","Taxi to university campus","Conference room booking","Printed marketing materials","Coffee meeting with partner","Airport transfer","Hotel restaurant dinner","Uber to client meeting"];
    const amount = Math.round((Math.random()*150+10)*100)/100;
    const currency = currencies[Math.floor(Math.random()*currencies.length)];
    const dayOffset = Math.floor(Math.random()*7);
    const receiptDate = new Date(Date.now() - dayOffset*86400000).toISOString().slice(0,10);
    const desc = descriptions[Math.floor(Math.random()*descriptions.length)];

    setScanResult({
      date: receiptDate,
      description: desc,
      amount,
      currency,
      amountGBP: toGBP(amount, currency),
      spentOn: "self"
    });
  };

  const addReceipt = () => {
    if(!scanResult) return;
    // Validate: check date is within claim period
    if(form.startDate && form.endDate) {
      const rd = new Date(scanResult.date);
      if(rd < new Date(form.startDate) || rd > new Date(form.endDate)) {
        setScanError("Receipt date is outside the claim period. Cannot log.");
        return;
      }
    }
    // Validate: no duplicate meals on same date
    const sameDateMeals = form.receipts.filter(r => r.date === scanResult.date && (r.description.toLowerCase().includes("lunch") || r.description.toLowerCase().includes("dinner") || r.description.toLowerCase().includes("breakfast")));
    if((scanResult.description.toLowerCase().includes("lunch") || scanResult.description.toLowerCase().includes("dinner") || scanResult.description.toLowerCase().includes("breakfast")) && sameDateMeals.length > 0) {
      setScanError("A meal receipt already exists for this date. Cannot log duplicate meals.");
      return;
    }

    setForm({...form, receipts:[...form.receipts, {...scanResult, id:Date.now()}]});
    setScanResult(null);
    setScanError("");
  };

  const submitClaim = () => {
    if(!form.name || form.receipts.length === 0) return;
    const validInst = form.institutions.filter(i => i);
    // Check all institutions have targets
    const invalidInst = validInst.filter(i => !hasTarget(i));
    if(invalidInst.length > 0) { setScanError(`No targets for: ${invalidInst.join(", ")}. Cannot claim expenses.`); return; }

    const claim = { ...form, id:Date.now(), ref:"EXP-"+Date.now().toString().slice(-6), status:"submitted", created:new Date().toISOString(), institutions:validInst, totalGBP: form.receipts.reduce((s,r) => s+r.amountGBP, 0) };
    save([claim, ...claims]);
    setForm({ name:"", linkedTrip:"", startDate:"", endDate:"", institutions:[""], receipts:[] });
    setShowForm(false);
    setScanResult(null);
  };

  return (
    <div>
      <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:20 }}>
        <div style={{ fontSize:12,color:"#8c9aab" }}>{claims.length} expense claim{claims.length!==1?"s":""}</div>
        <Btn gold icon="plus" onClick={() => setShowForm(!showForm)}>{showForm ? "Cancel" : "New Expense Claim"}</Btn>
      </div>

      {showForm && (
        <Card style={{ marginBottom:24,borderLeft:"3px solid var(--gold)" }}>
          <div style={{ fontSize:13,fontWeight:600,color:"var(--gold)",letterSpacing:1.5,textTransform:"uppercase",marginBottom:20 }}>New Expense Claim</div>

          <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:16 }}>
            <Input label="Claim Name" placeholder="e.g. Lagos Agent Visit Q1" value={form.name} onChange={e => setForm({...form,name:e.target.value})} />
            <Select label="Link to Travel Request (optional)" options={trips.map(t => t.tripName+" ("+t.ref+")")} value={form.linkedTrip} onChange={e => setForm({...form,linkedTrip:e.target.value})} />
            <Input label="Period From" type="date" value={form.startDate} onChange={e => setForm({...form,startDate:e.target.value})} />
            <Input label="Period To" type="date" value={form.endDate} onChange={e => setForm({...form,endDate:e.target.value})} />
          </div>

          {/* Institutions */}
          <div style={{ marginTop:16 }}>
            <div style={{ display:"flex",justifyContent:"space-between",marginBottom:6 }}>
              <label style={{ fontSize:11,fontWeight:600,color:"#8c9aab",textTransform:"uppercase",letterSpacing:1.2 }}>Institutions (must have targets)</label>
              {form.institutions.length < 3 && <button onClick={addInstitution} style={{ background:"none",border:"none",color:"var(--gold)",fontSize:11,cursor:"pointer",fontWeight:600 }}>+ Add</button>}
            </div>
            {form.institutions.map((inst,i) => (
              <select key={i} value={inst} onChange={e => updateInstitution(i,e.target.value)} style={{ width:"100%",padding:"10px 0",border:"none",borderBottom:"1px solid #d5d3ce",background:"transparent",color:"var(--navy)",fontSize:14,fontFamily:"var(--body)",outline:"none",marginBottom:6 }}>
                <option value="">Select university...</option>
                {UNIVERSITIES.map(u => <option key={u} value={u}>{u}</option>)}
              </select>
            ))}
          </div>

          {/* Receipts */}
          <div style={{ marginTop:20,padding:16,background:"#f7f6f3",borderRadius:8 }}>
            <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12 }}>
              <div style={{ fontSize:11,fontWeight:600,color:"var(--navy)",letterSpacing:1,textTransform:"uppercase" }}>Receipts ({form.receipts.length})</div>
              <Btn variant="secondary" onClick={scanReceipt} style={{ fontSize:10,padding:"8px 14px" }} icon="activity">Scan Receipt (AI)</Btn>
            </div>

            {scanResult && (
              <div style={{ padding:14,background:"#fff",borderRadius:6,border:"1px solid var(--gold)",marginBottom:12 }}>
                <div style={{ fontSize:11,fontWeight:600,color:"var(--gold)",marginBottom:8 }}>AI Scanned Receipt</div>
                <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,fontSize:12 }}>
                  <div><span style={{ color:"#8c9aab" }}>Date:</span> <strong>{scanResult.date}</strong></div>
                  <div><span style={{ color:"#8c9aab" }}>Amount:</span> <strong>{scanResult.amount} {scanResult.currency}</strong></div>
                  <div style={{ gridColumn:"1/3" }}><span style={{ color:"#8c9aab" }}>Description:</span> <strong>{scanResult.description}</strong></div>
                  <div><span style={{ color:"#8c9aab" }}>GBP:</span> <strong>£{scanResult.amountGBP}</strong></div>
                  <div>
                    <label style={{ fontSize:10,color:"#8c9aab" }}>Spent on:</label>
                    <select value={scanResult.spentOn} onChange={e => setScanResult({...scanResult,spentOn:e.target.value})} style={{ marginLeft:6,padding:"4px 8px",border:"1px solid #d5d3ce",borderRadius:4,fontSize:12,fontFamily:"var(--body)" }}>
                      <option value="self">Myself</option>
                      <option value="agent">Agent</option>
                    </select>
                  </div>
                </div>
                <div style={{ display:"flex",gap:8,marginTop:10 }}>
                  <Btn gold onClick={addReceipt} style={{ fontSize:10,padding:"8px 14px" }}>Accept & Add</Btn>
                  <Btn variant="ghost" onClick={() => { setScanResult(null); setScanError(""); }} style={{ fontSize:10,padding:"8px 14px" }}>Discard</Btn>
                </div>
              </div>
            )}

            {scanError && <div style={{ color:"#c0392b",fontSize:12,padding:"8px 0",fontWeight:500 }}>{scanError}</div>}

            {form.receipts.length === 0 ? <div style={{ color:"#8c9aab",fontSize:12,textAlign:"center",padding:16 }}>No receipts scanned yet. Click "Scan Receipt" to start.</div> :
              <div>
                {form.receipts.map((r,i) => (
                  <div key={r.id} style={{ display:"flex",justifyContent:"space-between",alignItems:"center",padding:"8px 0",borderBottom:"1px solid #e8e6e1",fontSize:12 }}>
                    <div>
                      <div style={{ fontWeight:500 }}>{r.description}</div>
                      <div style={{ color:"#8c9aab",fontSize:11 }}>{r.date} · {r.spentOn === "agent" ? "Agent" : "Self"}</div>
                    </div>
                    <div style={{ textAlign:"right" }}>
                      <div style={{ fontWeight:600 }}>{r.amount} {r.currency}</div>
                      <div style={{ color:"var(--gold)",fontSize:11,fontWeight:600 }}>£{r.amountGBP}</div>
                    </div>
                  </div>
                ))}
                <div style={{ display:"flex",justifyContent:"flex-end",marginTop:10,fontSize:14,fontWeight:700,fontFamily:"var(--serif)" }}>
                  Total: £{form.receipts.reduce((s,r) => s+r.amountGBP, 0).toFixed(2)}
                </div>
              </div>
            }
          </div>

          <div style={{ marginTop:16,display:"flex",justifyContent:"flex-end" }}>
            <Btn gold icon="send" onClick={submitClaim}>Submit Expense Claim</Btn>
          </div>
        </Card>
      )}

      {/* Claims list */}
      {claims.length === 0 && !showForm && <EmptyState icon="chart" title="No Expense Claims" sub="Start by creating a new expense claim" />}
      {claims.map(c => (
        <div key={c.id} style={{ display:"flex",alignItems:"center",gap:14,padding:"14px 0",borderBottom:"1px solid #f0eeeb" }}>
          <div style={{ width:42,height:42,borderRadius:4,background:"#f7f6f3",display:"flex",alignItems:"center",justifyContent:"center",color:"var(--gold)" }}><Icon name="chart" size={18} /></div>
          <div style={{ flex:1 }}>
            <div style={{ fontWeight:600,fontSize:14,fontFamily:"var(--serif)" }}>{c.name}</div>
            <div style={{ fontSize:11,color:"#8c9aab",marginTop:2 }}>{c.ref} · {c.receipts.length} receipts · {c.institutions.join(", ")}</div>
          </div>
          <div style={{ textAlign:"right" }}>
            <div style={{ fontWeight:700,fontSize:15,fontFamily:"var(--serif)",color:"var(--gold)" }}>£{c.totalGBP.toFixed(2)}</div>
            <Badge color={c.status==="submitted"?"var(--gold)":"#2d6a4f"}>{c.status}</Badge>
          </div>
        </div>
      ))}
    </div>
  );
}

// ─── PO REQUESTS ─────────────────────────────────────────────────
function PORequests({ user }) {
  const [pos, setPos] = useState([]);
  const [showForm, setShowForm] = useState(false);
  const [form, setForm] = useState({
    supplierName:"", serviceLocation:"", institutions:[""], description:"",
    amount:"", currency:"GBP", justification:"", contactName:"", contactEmail:"", contactPhone:""
  });

  useEffect(() => { store.get("poRequests").then(d => d && setPos(d)); }, []);
  const save = (p) => { setPos(p); store.set("poRequests", p); };

  const addInst = () => { if(form.institutions.length < 5) setForm({...form,institutions:[...form.institutions,""]}); };
  const updateInst = (i,v) => { const inst=[...form.institutions]; inst[i]=v; setForm({...form,institutions:inst}); };

  const submit = () => {
    if(!form.supplierName || !form.description || !form.amount) return;
    const amountNum = parseFloat(form.amount);
    if(amountNum > 700 && !form.justification) { return; } // justification required above 700
    const po = { ...form, id:Date.now(), ref:"PO-"+Date.now().toString().slice(-6), amount:amountNum, status:"submitted", created:new Date().toISOString(), institutions:form.institutions.filter(i=>i), submittedBy:user?.name||"" };
    save([po, ...pos]);
    setForm({ supplierName:"",serviceLocation:"",institutions:[""],description:"",amount:"",currency:"GBP",justification:"",contactName:"",contactEmail:"",contactPhone:"" });
    setShowForm(false);
  };

  const needsJustification = parseFloat(form.amount) > 700;

  return (
    <div>
      <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:20 }}>
        <div style={{ fontSize:12,color:"#8c9aab" }}>{pos.length} PO request{pos.length!==1?"s":""}</div>
        <Btn gold icon="plus" onClick={() => setShowForm(!showForm)}>{showForm ? "Cancel" : "New PO Request"}</Btn>
      </div>

      {showForm && (
        <Card style={{ marginBottom:24,borderLeft:"3px solid var(--gold)" }}>
          <div style={{ fontSize:13,fontWeight:600,color:"var(--gold)",letterSpacing:1.5,textTransform:"uppercase",marginBottom:20 }}>Purchase Order Request</div>

          <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:16 }}>
            <Input label="Supplier Name" value={form.supplierName} onChange={e => setForm({...form,supplierName:e.target.value})} />
            <Input label="Service Location" value={form.serviceLocation} onChange={e => setForm({...form,serviceLocation:e.target.value})} />
          </div>

