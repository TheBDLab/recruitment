        ))}
      </div>
      {showForm && (
        <Card style={{ marginBottom:24,borderLeft:"3px solid #c0392b" }}>
          <div style={{ fontSize:13,fontWeight:600,marginBottom:20,color:"#c0392b",letterSpacing:1.5,textTransform:"uppercase" }}>Urgent Admission Request</div>
          <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:20 }}>
            <Select label="University" options={UNIVERSITIES} value={form.university} onChange={e => setForm({...form, university:e.target.value})} />
            <Input label="Student ID" placeholder="e.g. STU-2026-0001" value={form.studentId} onChange={e => setForm({...form, studentId:e.target.value})} />
            <Select label="Priority" options={["urgent","high","medium"]} value={form.priority} onChange={e => setForm({...form, priority:e.target.value})} />
            <div />
            <div style={{ gridColumn:"1/3" }}><TextArea label="Issue Description" placeholder="Describe the issue in detail..." value={form.issue} onChange={e => setForm({...form, issue:e.target.value})} /></div>
          </div>
          <div style={{ marginTop:18,display:"flex",justifyContent:"flex-end" }}><Btn variant="danger" icon="send" onClick={submit}>Submit Request</Btn></div>
        </Card>
      )}
      {selected && (() => {
        const t = tickets.find(x => x.id === selected);
        if (!t) return null;
        return (
          <Card style={{ marginBottom:24,borderLeft:"3px solid var(--gold)" }}>
            <div style={{ display:"flex",justifyContent:"space-between",alignItems:"start" }}>
              <div>
                <div style={{ fontSize:18,fontWeight:400,fontFamily:"var(--serif)",color:"var(--navy)" }}>Ticket #{t.id.toString().slice(-4)}</div>
                <div style={{ display:"flex",gap:6,marginTop:8 }}><Badge color={PRIORITY_COLORS[t.priority]}>{t.priority}</Badge><Badge color={STATUS_COLORS[t.status]}>{t.status}</Badge><Badge gold>{t.university}</Badge></div>
              </div>
              <Btn variant="ghost" onClick={() => setSelected(null)}>Close</Btn>
            </div>
            <div style={{ marginTop:18,padding:18,background:"#f7f6f3",borderRadius:4 }}>
              <div style={{ fontSize:11,fontWeight:600,color:"#8c9aab",letterSpacing:1.2,marginBottom:6 }}>STUDENT ID: {t.studentId}</div>
              <div style={{ fontSize:14,color:"var(--navy)",lineHeight:1.7 }}>{t.issue}</div>
            </div>
            {t.feedback ? (
              <div style={{ marginTop:14,padding:18,background:"#2d6a4f0a",borderRadius:4,border:"1px solid #2d6a4f20" }}>
                <div style={{ fontSize:11,fontWeight:600,color:"#2d6a4f",letterSpacing:1.2,marginBottom:6 }}>ADMISSION TEAM FEEDBACK</div>
                <div style={{ fontSize:14,color:"var(--navy)",lineHeight:1.7 }}>{t.feedback}</div>
              </div>
            ) : (
              <div style={{ marginTop:14 }}>
                <div style={{ fontSize:11,fontWeight:600,color:"#8c9aab",letterSpacing:1.2,marginBottom:8 }}>PROVIDE FEEDBACK</div>
                <div style={{ display:"flex",gap:10 }}>
                  <textarea id={`fb-${t.id}`} placeholder="Type feedback..." style={{ flex:1,padding:12,borderRadius:4,border:"1px solid #d5d3ce",background:"#fff",color:"var(--navy)",fontSize:13,fontFamily:"var(--body)",resize:"none" }} />
                  <Btn gold onClick={() => { const el = document.getElementById(`fb-${t.id}`); if(el.value) addFeedback(t.id, el.value); }}>Reply</Btn>
                </div>
                <div style={{ display:"flex",gap:8,marginTop:10 }}>
                  <Btn variant="secondary" onClick={() => updateStatus(t.id, "in-progress")} style={{ fontSize:10,padding:"8px 14px" }}>In-Progress</Btn>
                  <Btn variant="danger" onClick={() => updateStatus(t.id, "rejected")} style={{ fontSize:10,padding:"8px 14px" }}>Reject</Btn>
                </div>
              </div>
            )}
          </Card>
        );
      })()}
      <div style={{ display:"flex",flexDirection:"column",gap:1 }}>
        {tickets.length === 0 && <EmptyState icon="ticket" title="No Requests" sub="Raise an urgent request to the admission team" />}
        {tickets.map(t => (
          <div key={t.id} onClick={() => setSelected(t.id)} style={{ display:"flex",alignItems:"center",gap:16,padding:"14px 0",borderBottom:"1px solid #f0eeeb",cursor:"pointer" }}>
            <div style={{ width:44,height:44,borderRadius:4,background:`${STATUS_COLORS[t.status]}0d`,display:"flex",alignItems:"center",justifyContent:"center",color:STATUS_COLORS[t.status],flexShrink:0 }}><Icon name="ticket" size={18} /></div>
            <div style={{ flex:1 }}>
              <div style={{ fontWeight:500,fontSize:14,fontFamily:"var(--serif)",color:"var(--navy)" }}>#{t.id.toString().slice(-4)} — {t.university}</div>
              <div style={{ fontSize:12,color:"#8c9aab",marginTop:3 }}>{t.issue.slice(0,60)}...</div>
            </div>
            <div style={{ display:"flex",flexDirection:"column",alignItems:"flex-end",gap:5 }}>
              <Badge color={STATUS_COLORS[t.status]}>{t.status}</Badge>
              {t.feedback && <Badge color="#2d6a4f">Feedback</Badge>}
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

// ─── SECTION 4: COMMAND CENTRE (Unified Dashboard + Reports) ─────
function CommandCentre() {
  const [data, setData] = useState(null);
  const [activities, setActivities] = useState([]);
  const [tasks, setTasks] = useState([]);
  const [view, setView] = useState("vitals");
  const [filterUni, setFilterUni] = useState("All");
  const [filterNat, setFilterNat] = useState("All");
  const [reportPeriod, setReportPeriod] = useState("weekly");

  useEffect(() => {
    store.get("salesData").then(d => {
      if (d) { setData(d); return; }
      const gen = {};
      INTAKES.forEach(intake => { gen[intake] = {}; UNIVERSITIES.forEach(uni => { gen[intake][uni] = { applicationTarget:Math.floor(Math.random()*40+20), applicationActual:Math.floor(Math.random()*35+5), depositTarget:Math.floor(Math.random()*30+10), depositActual:Math.floor(Math.random()*25+3), enrolmentTarget:Math.floor(Math.random()*20+5), enrolmentActual:Math.floor(Math.random()*18+1) }; }); });
      const monthly = {}; MONTHS.forEach(m => { monthly[m] = { appTarget:Math.floor(Math.random()*50+20), appActual:Math.floor(Math.random()*45+5), depTarget:Math.floor(Math.random()*30+10), depActual:Math.floor(Math.random()*25+2) }; });
      const agentPerf = SAMPLE_AGENTS.map(name => ({ name, applications:Math.floor(Math.random()*30+5), deposits:Math.floor(Math.random()*20+2), enrolments:Math.floor(Math.random()*15+1), nationality:NATIONALITIES[Math.floor(Math.random()*NATIONALITIES.length)], university:UNIVERSITIES[Math.floor(Math.random()*UNIVERSITIES.length)] }));
      const bonuses = [{ threshold:"10 deposits/month",bonus:"$500",status:"eligible" },{ threshold:"25 applications/intake",bonus:"$750",status:"in-progress" },{ threshold:"50 enrolments/year",bonus:"$2,000",status:"not-started" },{ threshold:"Top performer Q1",bonus:"$1,500",status:"eligible" }];
      const sd = { intakes:gen, monthly, agentPerf, bonuses };
      setData(sd); store.set("salesData", sd);
    });
    store.get("activities").then(d => d && setActivities(d));
    store.get("tasks").then(d => d && setTasks(d));
  }, []);

  if (!data) return <div style={{ padding:60,textAlign:"center",color:"#8c9aab",fontFamily:"var(--serif)" }}>Loading command centre...</div>;

  // ── Computed data ──
  const totals = { appTarget:0,appActual:0,depTarget:0,depActual:0,enrTarget:0,enrActual:0 };
  Object.values(data.intakes).forEach(intake => { Object.entries(intake).forEach(([uni, d]) => { if (filterUni!=="All"&&uni!==filterUni) return; totals.appTarget+=d.applicationTarget; totals.appActual+=d.applicationActual; totals.depTarget+=d.depositTarget; totals.depActual+=d.depositActual; totals.enrTarget+=d.enrolmentTarget; totals.enrActual+=d.enrolmentActual; }); });

  const now = new Date();
  const cutoff = reportPeriod === "weekly" ? new Date(now.getTime()-7*86400000) : new Date(now.getTime()-30*86400000);
  const periodAct = activities.filter(a => new Date(a.timestamp) >= cutoff);
  const completedTasks = tasks.filter(t => t.status === "done" && new Date(t.created) >= cutoff);
  const pendingTasks = tasks.filter(t => t.status !== "done");
  const prodScore = Math.min(100, Math.round((periodAct.length * 3 + completedTasks.length * 5) / (reportPeriod==="weekly"?1:4)));
  const prodColor = prodScore >= 80 ? "#2d6a4f" : prodScore >= 60 ? "var(--gold)" : prodScore >= 40 ? "#b8860b" : "#c0392b";
  const prodLabel = prodScore >= 80 ? "Excellent" : prodScore >= 60 ? "Good" : prodScore >= 40 ? "Moderate" : "Needs Attention";

  const actByType = {}; periodAct.forEach(a => { actByType[a.type] = (actByType[a.type]||0)+1; });
  const actByAgent = {}; periodAct.forEach(a => { if(a.agent) actByAgent[a.agent] = (actByAgent[a.agent]||0)+1; });

  const uniPerf = UNIVERSITIES.map(uni => {
    let at=0,aa=0,dt=0,da=0,et=0,ea=0;
    Object.values(data.intakes).forEach(intake => { if(intake[uni]) { at+=intake[uni].applicationTarget; aa+=intake[uni].applicationActual; dt+=intake[uni].depositTarget; da+=intake[uni].depositActual; et+=intake[uni].enrolmentTarget; ea+=intake[uni].enrolmentActual; } });
    return { uni, at, aa, dt, da, et, ea };
  });

  // ── Metric ring component ──
  const Ring = ({ value, max, size=90, stroke=6, color, label, sublabel }) => {
    const pct = max > 0 ? Math.min(value/max,1) : 0;
    const r = (size-stroke)/2;
    const circ = 2*Math.PI*r;
    return (
      <div style={{ textAlign:"center" }}>
        <svg width={size} height={size} style={{ transform:"rotate(-90deg)" }}>
          <circle cx={size/2} cy={size/2} r={r} fill="none" stroke="#e8e6e1" strokeWidth={stroke} />
          <circle cx={size/2} cy={size/2} r={r} fill="none" stroke={color} strokeWidth={stroke} strokeDasharray={circ} strokeDashoffset={circ*(1-pct)} strokeLinecap="round" style={{ transition:"stroke-dashoffset .8s ease" }} />
        </svg>
        <div style={{ marginTop:-size/2-8,position:"relative" }}>
          <div style={{ fontSize:20,fontWeight:700,fontFamily:"var(--serif)",color:"var(--navy)" }}>{Math.round(pct*100)}%</div>
        </div>
        <div style={{ marginTop:size/2-14 }}>
          <div style={{ fontSize:11,fontWeight:600,color:"var(--navy)",marginTop:4 }}>{label}</div>
          <div style={{ fontSize:10,color:"#8c9aab" }}>{sublabel}</div>
        </div>
      </div>
    );
  };

  return (
    <div>
      {/* ── HEADER ── */}
      <div style={{ display:"flex",justifyContent:"space-between",alignItems:"flex-end",marginBottom:20 }}>
        <div>
          <div style={{ fontSize:11,fontWeight:600,color:"var(--gold)",textTransform:"uppercase",letterSpacing:2.5,marginBottom:6 }}>Command Centre</div>
          <div style={{ fontSize:26,fontWeight:400,color:"var(--navy)",fontFamily:"var(--serif)",lineHeight:1.1 }}>Your Performance Hub</div>
        </div>
        <div style={{ display:"flex",gap:8,alignItems:"center" }}>
          <select value={filterUni} onChange={e => setFilterUni(e.target.value)} style={{ padding:"9px 14px",borderRadius:4,border:"1px solid #d5d3ce",background:"#fff",color:"var(--navy)",fontSize:11,fontFamily:"var(--body)" }}>
            <option value="All">All Universities</option>{UNIVERSITIES.map(u => <option key={u} value={u}>{u}</option>)}
          </select>
          <select value={reportPeriod} onChange={e => setReportPeriod(e.target.value)} style={{ padding:"9px 14px",borderRadius:4,border:"1px solid #d5d3ce",background:"#fff",color:"var(--navy)",fontSize:11,fontFamily:"var(--body)" }}>
            <option value="weekly">This Week</option>
            <option value="monthly">This Month</option>
          </select>
        </div>
      </div>

      {/* ══════════ VITALS STRIP ══════════ */}
      <div style={{ display:"grid",gridTemplateColumns:"2fr 1fr 1fr 1fr",gap:14,marginBottom:20 }}>
        {/* Productivity card */}
        <Card gold style={{ display:"flex",alignItems:"center",gap:20,padding:20 }}>
          <div>
            <svg width={80} height={80} style={{ transform:"rotate(-90deg)" }}>
              <circle cx={40} cy={40} r={34} fill="none" stroke="#d4a84730" strokeWidth={6} />
              <circle cx={40} cy={40} r={34} fill="none" stroke={prodColor} strokeWidth={6} strokeDasharray={213.6} strokeDashoffset={213.6*(1-prodScore/100)} strokeLinecap="round" style={{ transition:"stroke-dashoffset .8s ease" }} />
            </svg>
            <div style={{ marginTop:-54,textAlign:"center",position:"relative" }}>
              <div style={{ fontSize:22,fontWeight:800,fontFamily:"var(--serif)",color:prodColor }}>{prodScore}</div>
            </div>
          </div>
          <div style={{ marginTop:0 }}>
            <div style={{ fontSize:10,fontWeight:600,color:"var(--gold)",letterSpacing:1.5,textTransform:"uppercase" }}>Productivity</div>
            <div style={{ fontSize:20,fontWeight:700,fontFamily:"var(--serif)",color:"var(--navy)",marginTop:2 }}>{prodLabel}</div>
            <div style={{ fontSize:11,color:"#8c9aab",marginTop:4 }}>{periodAct.length} activities · {completedTasks.length} tasks done</div>
            <div style={{ fontSize:11,color:pendingTasks.length > 5 ? "#c0392b" : "#8c9aab",fontWeight:pendingTasks.length > 5 ? 600 : 400,marginTop:2 }}>{pendingTasks.length} pending follow-ups</div>
          </div>
        </Card>
        {/* KPI rings */}
        {[
          { label:"Applications", sub:`${totals.appActual} of ${totals.appTarget}`, val:totals.appActual, max:totals.appTarget, color:"var(--navy)" },
          { label:"Deposits", sub:`${totals.depActual} of ${totals.depTarget}`, val:totals.depActual, max:totals.depTarget, color:"var(--gold)" },
          { label:"Enrolments", sub:`${totals.enrActual} of ${totals.enrTarget}`, val:totals.enrActual, max:totals.enrTarget, color:"#2d6a4f" },
        ].map(k => (
          <Card key={k.label} style={{ display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:16 }}>
            <Ring value={k.val} max={k.max} color={k.color} size={78} stroke={5} label={k.label} sublabel={k.sub} />
          </Card>
        ))}
      </div>

      {/* ══════════ TABS ══════════ */}
      <TabBar tabs={[
        {id:"vitals",label:"Targets & Intakes"},
        {id:"monthly",label:"Monthly Trends"},
        {id:"activity",label:"Activity Report"},
        {id:"agents",label:"Agent Performance"},
        {id:"bonuses",label:"Bonuses"},
      ]} active={view} onChange={setView} />

      <div style={{ marginTop:20 }}>
        {/* ── TARGETS & INTAKES ── */}
        {view === "vitals" && (<>
          {/* Institution performance table */}
          <Card style={{ marginBottom:16 }}>
            <div style={{ fontSize:14,fontFamily:"var(--serif)",color:"var(--navy)",marginBottom:16 }}>Performance by Institution</div>
            <div style={{ overflowX:"auto" }}>
              <table style={{ width:"100%",borderCollapse:"collapse",fontSize:12 }}>
                <thead><tr style={{ borderBottom:"2px solid #e8e6e1" }}>
                  {["Institution","Apps","","Deposits","","Enrolments","","Health"].map((h,i) => (
                    <th key={i} style={{ textAlign:"left",padding:"10px 8px",fontSize:10,fontWeight:600,color:"#8c9aab",textTransform:"uppercase",letterSpacing:.8 }}>{h}</th>
                  ))}
                </tr></thead>
                <tbody>{uniPerf.filter(u => filterUni==="All" || u.uni===filterUni).map(u => {
                  const appP = u.at>0?Math.round(u.aa/u.at*100):0;
                  const depP = u.dt>0?Math.round(u.da/u.dt*100):0;
                  const enrP = u.et>0?Math.round(u.ea/u.et*100):0;
                  const health = Math.round((appP+depP+enrP)/3);
                  const hColor = health>=70?"#2d6a4f":health>=45?"var(--gold)":"#c0392b";
                  return (
                    <tr key={u.uni} style={{ borderBottom:"1px solid #f0eeeb" }}>
                      <td style={{ padding:"12px 8px",fontWeight:600,fontFamily:"var(--serif)",fontSize:13 }}>{u.uni}</td>
                      <td style={{ padding:"12px 8px" }}><span style={{ fontWeight:700,color:"var(--navy)" }}>{u.aa}</span><span style={{ color:"#b8b5ae" }}>/{u.at}</span></td>
                      <td style={{ padding:"12px 8px",width:60 }}><ProgressBar value={u.aa} max={u.at} color="var(--navy)" height={4} /></td>
                      <td style={{ padding:"12px 8px" }}><span style={{ fontWeight:700,color:"var(--gold)" }}>{u.da}</span><span style={{ color:"#b8b5ae" }}>/{u.dt}</span></td>
                      <td style={{ padding:"12px 8px",width:60 }}><ProgressBar value={u.da} max={u.dt} color="var(--gold)" height={4} /></td>
                      <td style={{ padding:"12px 8px" }}><span style={{ fontWeight:700,color:"#2d6a4f" }}>{u.ea}</span><span style={{ color:"#b8b5ae" }}>/{u.et}</span></td>
                      <td style={{ padding:"12px 8px",width:60 }}><ProgressBar value={u.ea} max={u.et} color="#2d6a4f" height={4} /></td>
                      <td style={{ padding:"12px 8px" }}><Badge color={hColor} style={{ fontSize:11,padding:"4px 10px" }}>{health}%</Badge></td>
                    </tr>
                  );
                })}</tbody>
              </table>
            </div>
          </Card>

          {/* Intake breakdown */}
          <Card>
            <div style={{ fontSize:14,fontFamily:"var(--serif)",color:"var(--navy)",marginBottom:16 }}>By Intake Period</div>
            {INTAKES.map((intake,idx) => {
              const iData = data.intakes[intake]; let apps=0,deps=0,enr=0,at=0,dt=0,et=0;
              Object.entries(iData).forEach(([uni,d]) => { if(filterUni!=="All"&&uni!==filterUni) return; apps+=d.applicationActual;at+=d.applicationTarget;deps+=d.depositActual;dt+=d.depositTarget;enr+=d.enrolmentActual;et+=d.enrolmentTarget; });
