// ─── TRAVEL REQUESTS ─────────────────────────────────────────────
function TravelRequests({ user }) {
  const [trips, setTrips] = useState([]);
  const [showForm, setShowForm] = useState(false);
  const [selected, setSelected] = useState(null);
  const [form, setForm] = useState({
    tripName:"", startDate:"", endDate:"", fullName: user?.name || "", lineManager:"",
    costCentres:[""], journeys:[{from:"",to:""}], hotels:[{name:"",checkIn:"",checkOut:""}]
  });

  useEffect(() => { store.get("travelRequests").then(d => d && setTrips(d)); }, []);
  const save = (t) => { setTrips(t); store.set("travelRequests", t); };

  const addJourney = () => { if(form.journeys.length < 10) setForm({...form, journeys:[...form.journeys, {from:"",to:""}]}); };
  const addHotel = () => { if(form.hotels.length < 10) setForm({...form, hotels:[...form.hotels, {name:"",checkIn:"",checkOut:""}]}); };
  const addCostCentre = () => { if(form.costCentres.length < 3) setForm({...form, costCentres:[...form.costCentres, ""]}); };

  const updateJourney = (i,field,val) => { const j=[...form.journeys]; j[i]={...j[i],[field]:val}; setForm({...form,journeys:j}); };
  const updateHotel = (i,field,val) => { const h=[...form.hotels]; h[i]={...h[i],[field]:val}; setForm({...form,hotels:h}); };
  const updateCostCentre = (i,val) => { const c=[...form.costCentres]; c[i]=val; setForm({...form,costCentres:c}); };

  const submit = () => {
    if(!form.tripName || !form.startDate || !form.fullName || !form.lineManager) return;
    const ref = "TRV-" + Date.now().toString().slice(-6);
    const trip = { ...form, id:Date.now(), ref, status:"pending_approval", created:new Date().toISOString(), approvedBy:null, approvalDate:null, costCentres:form.costCentres.filter(c=>c) };
    save([trip, ...trips]);
