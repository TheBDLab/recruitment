  const [selected, setSelected] = useState(null);

  useEffect(() => { store.get("tickets").then(d => d && setTickets(d)); }, []);
  const save = (t) => { setTickets(t); store.set("tickets", t); };

  const submit = () => {
    if (!form.university || !form.studentId || !form.issue) return;
    save([{ ...form, id: Date.now(), status:"pending", created: new Date().toISOString(), feedback:null, feedbackDate:null }, ...tickets]);
