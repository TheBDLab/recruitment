    setShowForm(false);
  };
  const addFeedback = (id, fb) => { save(tickets.map(t => t.id === id ? { ...t, feedback:fb, feedbackDate:new Date().toISOString(), status:"resolved" } : t)); setSelected(null); };
  const updateStatus = (id, status) => save(tickets.map(t => t.id === id ? { ...t, status } : t));

  return (
