              <div key={i} style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:8,padding:10,background:"#f7f6f3",borderRadius:6 }}>
                <Input label={`Leg ${i+1} From`} value={j.from} onChange={e => updateJourney(i,"from",e.target.value)} />
                <Input label={`Leg ${i+1} To`} value={j.to} onChange={e => updateJourney(i,"to",e.target.value)} />
              </div>
            ))}
          </div>

          {/* Hotels */}
          <div style={{ marginTop:20 }}>
            <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8 }}>
              <label style={{ fontSize:11,fontWeight:600,color:"#8c9aab",textTransform:"uppercase",letterSpacing:1.2 }}>Hotels ({form.hotels.length}/10)</label>
              {form.hotels.length < 10 && <button onClick={addHotel} style={{ background:"none",border:"none",color:"var(--gold)",fontSize:11,cursor:"pointer",fontWeight:600 }}>+ Add Hotel</button>}
            </div>
            {form.hotels.map((h,i) => (
              <div key={i} style={{ display:"grid",gridTemplateColumns:"2fr 1fr 1fr",gap:10,marginBottom:8,padding:10,background:"#f7f6f3",borderRadius:6 }}>
                <Input label="Hotel Name" value={h.name} onChange={e => updateHotel(i,"name",e.target.value)} />
                <Input label="Check-in" type="date" value={h.checkIn} onChange={e => updateHotel(i,"checkIn",e.target.value)} />
                <Input label="Check-out" type="date" value={h.checkOut} onChange={e => updateHotel(i,"checkOut",e.target.value)} />
              </div>
            ))}
          </div>

          <div style={{ marginTop:20,display:"flex",justifyContent:"flex-end",gap:8 }}>
            <Btn variant="secondary" onClick={() => setShowForm(false)}>Cancel</Btn>
            <Btn gold icon="send" onClick={submit}>Submit for Approval</Btn>
          </div>
          <div style={{ marginTop:10,fontSize:11,color:"#8c9aab",textAlign:"right" }}>Requires Team Leader approval before extraction. Final form approved by Marina Sunehag.</div>
        </Card>
      )}

      {/* Selected trip detail */}
      {selected && (() => {
        const t = trips.find(x => x.id === selected);
        if(!t) return null;
        return (
          <Card style={{ marginBottom:20,borderLeft:"3px solid var(--gold)" }}>
            <div style={{ display:"flex",justifyContent:"space-between",alignItems:"start" }}>
              <div>
                <div style={{ fontSize:18,fontFamily:"var(--serif)",color:"var(--navy)" }}>{t.tripName}</div>
                <div style={{ display:"flex",gap:6,marginTop:6 }}>
                  <Badge gold>{t.ref}</Badge>
                  <Badge color={t.status==="approved"?"#2d6a4f":t.status==="pending_approval"?"var(--gold)":"#c0392b"}>{t.status.replace("_"," ")}</Badge>
                </div>
              </div>
              <Btn variant="ghost" onClick={() => setSelected(null)}>Close</Btn>
            </div>
            <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginTop:16 }}>
              <div style={{ fontSize:12 }}><span style={{ color:"#8c9aab" }}>Full Name:</span> <strong>{t.fullName}</strong></div>
              <div style={{ fontSize:12 }}><span style={{ color:"#8c9aab" }}>Line Manager:</span> <strong>{t.lineManager}</strong></div>
              <div style={{ fontSize:12 }}><span style={{ color:"#8c9aab" }}>Dates:</span> <strong>{t.startDate} — {t.endDate}</strong></div>
