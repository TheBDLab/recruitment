// ─── GOLDEN COIN CELEBRATION ─────────────────────────────────────
function CoinCelebration({ count, onDone }) {
  const [coins, setCoins] = useState([]);
  const [show, setShow] = useState(true);

  useEffect(() => {
    const generated = [];
    for (let i = 0; i < 40; i++) {
      generated.push({
        id: i,
        left: Math.random() * 100,
        delay: Math.random() * 1.2,
        duration: 1.8 + Math.random() * 1.5,
        size: 18 + Math.random() * 22,
        rotation: Math.random() * 720 - 360,
        xDrift: (Math.random() - 0.5) * 120,
      });
    }
    setCoins(generated);
    const timer = setTimeout(() => { setShow(false); if(onDone) onDone(); }, 5000);
    return () => clearTimeout(timer);
  }, []);

  if (!show) return null;

  return (
    <div style={{ position:"fixed",inset:0,zIndex:9999,pointerEvents:"auto",display:"flex",alignItems:"center",justifyContent:"center" }} onClick={() => { setShow(false); if(onDone) onDone(); }}>
      <div style={{ position:"absolute",inset:0,background:"rgba(26,42,58,.7)",backdropFilter:"blur(4px)" }} />
      <style>{`
        @keyframes coinFall {
          0% { transform: translateY(-120vh) translateX(0px) rotate(0deg); opacity:0; }
          10% { opacity:1; }
          100% { transform: translateY(110vh) translateX(var(--xd)) rotate(var(--rot)); opacity:0; }
        }
        @keyframes coinPulse { 0%,100% { transform:scale(1); } 50% { transform:scale(1.08); } }
        @keyframes celebFade { 0% { opacity:0; transform:scale(0.8) translateY(20px); } 100% { opacity:1; transform:scale(1) translateY(0); } }
      `}</style>

      {/* Falling coins */}
      {coins.map(c => (
        <div key={c.id} style={{
          position:"fixed", left:`${c.left}%`, top:0, zIndex:10000,
          animation:`coinFall ${c.duration}s ${c.delay}s ease-in forwards`,
          "--xd":`${c.xDrift}px`, "--rot":`${c.rotation}deg`
        }}>
          <svg width={c.size} height={c.size} viewBox="0 0 40 40">
            <defs>
              <radialGradient id={`cg${c.id}`} cx="40%" cy="35%">
                <stop offset="0%" stopColor="#f5d670"/>
                <stop offset="50%" stopColor="#d4a847"/>
                <stop offset="100%" stopColor="#96710a"/>
              </radialGradient>
            </defs>
            <circle cx="20" cy="20" r="18" fill={`url(#cg${c.id})`} stroke="#96710a" strokeWidth="1.5"/>
            <circle cx="20" cy="20" r="13" fill="none" stroke="#f5d670" strokeWidth="0.8" opacity="0.5"/>
            <text x="20" y="24" textAnchor="middle" fontSize="14" fontWeight="800" fill="#96710a" fontFamily="serif">$</text>
          </svg>
        </div>
      ))}

      {/* Center message */}
      <div style={{ position:"relative",zIndex:10001,textAlign:"center",animation:"celebFade .6s .3s ease both" }}>
        <div style={{ width:100,height:100,borderRadius:"50%",background:"linear-gradient(135deg,#d4a847,#f5d670)",margin:"0 auto 24px",display:"flex",alignItems:"center",justifyContent:"center",boxShadow:"0 0 60px rgba(212,168,71,.5), 0 0 120px rgba(212,168,71,.2)",animation:"coinPulse 1.5s ease infinite" }}>
          <svg width="48" height="48" viewBox="0 0 40 40">
            <circle cx="20" cy="20" r="18" fill="none" stroke="#96710a" strokeWidth="1.5"/>
            <text x="20" y="25" textAnchor="middle" fontSize="18" fontWeight="800" fill="#96710a" fontFamily="serif">$</text>
          </svg>
        </div>
        <div style={{ color:"#f5d670",fontSize:14,fontWeight:700,letterSpacing:3,textTransform:"uppercase",marginBottom:10 }}>New Deposit{count > 1 ? "s" : ""} Received!</div>
        <div style={{ color:"#ffffff",fontSize:48,fontWeight:800,fontFamily:"var(--serif)",lineHeight:1,marginBottom:8 }}>+{count}</div>
        <div style={{ color:"#ffffff",fontSize:16,fontWeight:500,opacity:.8,marginBottom:24 }}>
          {count === 1 ? "A new deposit just landed!" : `${count} new deposits just landed!`}
        </div>
        <div style={{ color:"#ffffff",fontSize:20,fontWeight:700,fontFamily:"var(--serif)" }}>Keep going, superstar!</div>
        <div style={{ color:"rgba(255,255,255,.4)",fontSize:12,marginTop:20 }}>Tap anywhere to continue</div>
      </div>
    </div>
  );
}

