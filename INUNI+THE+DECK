          <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:16 }}>
            <Input label="Full Name" value={form.fullName} onChange={e => setForm({...form,fullName:e.target.value})} />
            <Input label="Line Manager" value={form.lineManager} onChange={e => setForm({...form,lineManager:e.target.value})} />
            <Input label="Trip Name" value={form.tripName} onChange={e => setForm({...form,tripName:e.target.value})} />
            <div />
            <Input label="Start Date" type="date" value={form.startDate} onChange={e => setForm({...form,startDate:e.target.value})} />
            <Input label="End Date" type="date" value={form.endDate} onChange={e => setForm({...form,endDate:e.target.value})} />
          </div>

          {/* Cost Centres */}
          <div style={{ marginTop:20 }}>
            <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8 }}>
              <label style={{ fontSize:11,fontWeight:600,color:"#8c9aab",textTransform:"uppercase",letterSpacing:1.2 }}>University Cost Centre{form.costCentres.length>1?"s":""}</label>
              {form.costCentres.length < 3 && <button onClick={addCostCentre} style={{ background:"none",border:"none",color:"var(--gold)",fontSize:11,cursor:"pointer",fontWeight:600 }}>+ Add</button>}
            </div>
            {form.costCentres.map((c,i) => (
              <div key={i} style={{ marginBottom:6 }}>
                <select value={c} onChange={e => updateCostCentre(i,e.target.value)} style={{ width:"100%",padding:"10px 0",border:"none",borderBottom:"1px solid #d5d3ce",background:"transparent",color:"var(--navy)",fontSize:14,fontFamily:"var(--body)",outline:"none" }}>
                  <option value="">Select university...</option>
                  {UNIVERSITIES.map(u => <option key={u} value={u}>{u}</option>)}
                </select>
              </div>
            ))}
          </div>

          {/* Journeys */}
          <div style={{ marginTop:20 }}>
            <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8 }}>
              <label style={{ fontSize:11,fontWeight:600,color:"#8c9aab",textTransform:"uppercase",letterSpacing:1.2 }}>Journey Legs ({form.journeys.length}/10)</label>
              {form.journeys.length < 10 && <button onClick={addJourney} style={{ background:"none",border:"none",color:"var(--gold)",fontSize:11,cursor:"pointer",fontWeight:600 }}>+ Add Leg</button>}
            </div>
