      <div style={{ display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:14,marginBottom:24 }}>
        {[{l:"Pending",v:tickets.filter(t=>t.status==="pending").length,c:"var(--gold)"},{l:"In Progress",v:tickets.filter(t=>t.status==="in-progress").length,c:"var(--navy)"},{l:"Resolved",v:tickets.filter(t=>t.status==="resolved").length,c:"#2d6a4f"},{l:"Total",v:tickets.length,c:"#8c9aab"}].map(m => (
