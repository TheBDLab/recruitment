                          <span style={{ fontSize:11,fontWeight:600,color:m.c }}>{m.t>0?Math.round(m.a/m.t*100):0}%</span>
                        </div>
                        <ProgressBar value={m.a} max={m.t} color={m.c} height={5} />
                        <div style={{ display:"flex",justifyContent:"space-between",marginTop:4 }}>
                          <span style={{ fontSize:12,fontWeight:700,color:m.c }}>{m.a}</span>
                          <span style={{ fontSize:11,color:"#b8b5ae" }}>of {m.t}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              );
            })}
          </Card>
        </>)}

        {/* ── MONTHLY TRENDS ── */}
        {view === "monthly" && (
          <Card>
            <div style={{ fontSize:14,fontFamily:"var(--serif)",color:"var(--navy)",marginBottom:24 }}>Monthly Trends</div>
            <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:30 }}>
              {[{label:"Applications",key:"appActual",tkey:"appTarget",color:"var(--navy)",max:55},{label:"Deposits",key:"depActual",tkey:"depTarget",color:"var(--gold)",max:35}].map(ch => (
                <div key={ch.label}>
                  <div style={{ fontSize:10,fontWeight:600,color:ch.color,letterSpacing:1.5,textTransform:"uppercase",marginBottom:14 }}>{ch.label}</div>
                  <div style={{ display:"flex",alignItems:"flex-end",gap:3,height:150 }}>
                    {MONTHS.map(m => {
                      const val = data.monthly[m][ch.key];
                      const tgt = data.monthly[m][ch.tkey];
                      const pct = val/(ch.max)*100;
                      const hit = tgt > 0 && val >= tgt;
                      return (
                        <div key={m} style={{ flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:3 }}>
                          <div style={{ fontSize:9,fontWeight:600,color: hit ? "#2d6a4f" : ch.color }}>{val}</div>
                          <div style={{ width:"100%",borderRadius:"3px 3px 0 0",height:`${pct}%`,minHeight:3,background: hit ? "#2d6a4f" : ch.color,opacity: hit ? 1 : 0.7,transition:"height .5s" }} />
                          <div style={{ fontSize:9,color:"#8c9aab",fontWeight:500 }}>{m}</div>
                        </div>
                      );
                    })}
                  </div>
                  <div style={{ fontSize:10,color:"#8c9aab",marginTop:8,display:"flex",alignItems:"center",gap:8 }}>
                    <span style={{ width:8,height:8,borderRadius:2,background:ch.color,opacity:.7,display:"inline-block" }} /> Actual
                    <span style={{ width:8,height:8,borderRadius:2,background:"#2d6a4f",display:"inline-block",marginLeft:8 }} /> Target met
                  </div>
                </div>
              ))}
            </div>
          </Card>
        )}

        {/* ── ACTIVITY REPORT ── */}
        {view === "activity" && (<>
          <div style={{ display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:14,marginBottom:20 }}>
