              <td style={{ padding:"10px",color:"var(--gold)",fontWeight:600 }}>{period==="year"?a.deps:a.monthDeps}</td>
              <td style={{ padding:"10px",color:"#2d6a4f",fontWeight:600 }}>{period==="year"?a.enr:"-"}</td>
              <td style={{ padding:"10px",fontWeight:700,fontSize:16,fontFamily:"var(--serif)" }}>{score}</td>
            </tr>); })}</tbody>
