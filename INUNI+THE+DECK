                  <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12 }}>
                    <span style={{ fontWeight:600,fontSize:14,fontFamily:"var(--serif)",color:"var(--navy)" }}>{intake}</span>
                    <Badge color={Math.round((apps/(at||1)+deps/(dt||1)+enr/(et||1))/3*100) >= 60 ? "#2d6a4f" : "var(--gold)"}>{Math.round((apps/(at||1)+deps/(dt||1)+enr/(et||1))/3*100)}% avg</Badge>
                  </div>
                  <div style={{ display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:16 }}>
                    {[{l:"Applications",a:apps,t:at,c:"var(--navy)"},{l:"Deposits",a:deps,t:dt,c:"var(--gold)"},{l:"Enrolments",a:enr,t:et,c:"#2d6a4f"}].map(m => (
                      <div key={m.l}>
                        <div style={{ display:"flex",justifyContent:"space-between",marginBottom:6 }}>
