            </div>
            <div style={{ marginTop:14,fontSize:11,fontWeight:600,color:"#8c9aab",letterSpacing:1 }}>JOURNEYS</div>
            {t.journeys.filter(j=>j.from||j.to).map((j,i) => <div key={i} style={{ fontSize:12,padding:"4px 0" }}>{i+1}. {j.from} → {j.to}</div>)}
            <div style={{ marginTop:10,fontSize:11,fontWeight:600,color:"#8c9aab",letterSpacing:1 }}>HOTELS</div>
            {t.hotels.filter(h=>h.name).map((h,i) => <div key={i} style={{ fontSize:12,padding:"4px 0" }}>{h.name} ({h.checkIn} — {h.checkOut})</div>)}
            {t.approvedBy && (
              <div style={{ marginTop:14,padding:12,background:"#2d6a4f0a",borderRadius:6,border:"1px solid #2d6a4f20" }}>
                <div style={{ fontSize:11,fontWeight:600,color:"#2d6a4f",letterSpacing:1 }}>APPROVED</div>
